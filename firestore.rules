rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Ai cũng đọc được (trang portfolio công khai)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /profile/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Mặc định chặn hết
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
